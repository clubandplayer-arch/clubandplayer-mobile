{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "target": "es2017"
  },
  "include": [
    "App.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "index.ts",
    "app.config.ts"
  ],
  "exclude": [
    "node_modules",
    "web",
    "web/**"
  ]
}
